            {
                Height = 1,
                Dock = DockStyle.Top,
                BackColor = Color.FromArgb(30, 255, 255, 255)
            };

            // ── Panel usuario (parte inferior) ──
            var pnlUser = new Panel
            {
                Height = 70,
                Dock = DockStyle.Bottom,
                BackColor = Color.FromArgb(8, 12, 28),
                Padding = new Padding(16, 14, 16, 14)
            };
            pnlUser.Paint += (s, e) =>
            {
                var g = e.Graphics;
                g.SmoothingMode = SmoothingMode.AntiAlias;

                using var avBrush = new LinearGradientBrush(
                    new Rectangle(0, 8, 38, 38),
                    ColAccent, ColAccentLight, 135f);
                g.FillEllipse(avBrush, 0, 8, 38, 38);

                TextRenderer.DrawText(g, "👤",
                    new Font("Segoe UI Emoji", 13f),
                    new Rectangle(0, 8, 38, 38), Color.White,
                    TextFormatFlags.HorizontalCenter | TextFormatFlags.VerticalCenter);

                TextRenderer.DrawText(g, "Estudiante",
                    new Font("Segoe UI", 9f, FontStyle.Bold),
                    new Rectangle(46, 8, 160, 22), ColText,
                    TextFormatFlags.Left | TextFormatFlags.VerticalCenter);

                TextRenderer.DrawText(g, "Nivel: Principiante",
                    new Font("Segoe UI", 7.5f),
                    new Rectangle(46, 30, 160, 18), ColMuted,
