            pnlTopBar.Controls.Add(lblTitle);
            pnlTopBar.Controls.Add(lblSubtitle);
            pnlTopBar.Controls.Add(pnlSearchBox);
            pnlTopBar.Controls.Add(lblCoursesCount);

            // ── Posicionar searchbox y contador a la derecha ──
