using System;
using System.Collections.Generic;
using System.Drawing;
using System.Drawing.Drawing2D;
using System.Windows.Forms;
using CodeAcademy.Controls;
using CodeAcademy.Data;
using CodeAcademy.Models;
using CodeAcademy.Presenters;

namespace CodeAcademy.Views
{
    public class MainForm : Form, IMainView
    {
        // ─── Controles ───
        private Panel pnlSidebar;
        private Panel pnlTopBar;
        private Panel pnlContent;
        private FlowLayoutPanel flpCourses;
        // Presenter almacenado para controlar su ciclo de vida
        private MainPresenter _presenter;
        private TextBox txtSearch;
        private ListBox lstCategories;
        private Label lblTitle;
        private Label lblSubtitle;
        private Label lblCoursesCount;
        private Panel pnlSearchBox;

        // ─── IMainView ───
        public string SearchText => txtSearch.Text;
        public string SelectedCategory => lstCategories.SelectedItem?.ToString() ?? "Todos";
        public event EventHandler SearchChanged;
        public event EventHandler CategoryChanged;
        public event Action<Course> CourseSelected;

        // ─── Paleta de colores ───
        private readonly Color ColPrimary = Color.FromArgb(15, 23, 42);
        private readonly Color ColSidebar = Color.FromArgb(10, 16, 36);
        private readonly Color ColAccent = Color.FromArgb(99, 102, 241);
        private readonly Color ColAccentLight = Color.FromArgb(129, 140, 248);
        private readonly Color ColBg = Color.FromArgb(245, 247, 255);
        private readonly Color ColText = Color.FromArgb(248, 250, 252);
        private readonly Color ColMuted = Color.FromArgb(148, 163, 184);

        public MainForm()
        {
            SetupForm();
            BuildSidebar();
            BuildTopBar();
            BuildContent();           // ← construye el área de tarjetas
            WireResize();             // ← conecta el evento de redimensión

            // Crear presenter pero posponer la carga de datos hasta el evento Load
            _presenter = new MainPresenter(this, new CourseRepository());
            this.Load += (s, e) => _presenter.LoadCourses();
        }

        // ══════════════════════════════════════════════════════
        //  CONFIGURACIÓN GENERAL DEL FORM
        // ══════════════════════════════════════════════════════
        private void SetupForm()
        {
            Text = "CodeAcademy — Aprende a programar";
            Size = new Size(1200, 780);
            MinimumSize = new Size(900, 600);
            StartPosition = FormStartPosition.CenterScreen;
            BackColor = ColBg;
            Font = new Font("Segoe UI", 9f);
            DoubleBuffered = true;
        }

