            Controls.Add(pnlTopBar);
        }

        // Centraliza la lógica de posicionamiento derecho del topbar
        // CAMBIO: antes estaba inline en el lambda; ahora es un método
        // para poder llamarlo también en el primer render (antes del Resize)
        private void PositionTopBarRight()
        {
            pnlSearchBox.Location = new Point(pnlTopBar.Width - 318, 18);
            lblCoursesCount.Location = new Point(pnlTopBar.Width - 318, 60);
        }

        // ══════════════════════════════════════════════════════
        //  ÁREA DE TARJETAS
        // ══════════════════════════════════════════════════════
        private void BuildContent()
        {
            // Panel contenedor con padding visual uniforme
            pnlContent = new Panel
            {
                Dock = DockStyle.Fill,
                BackColor = ColBg,
                Padding = new Padding(20, 20, 20, 20),
                AutoScroll = false   // el scroll lo maneja flpCourses
            };

            // FlowLayoutPanel: distribuye las tarjetas en filas
            flpCourses = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                AutoScroll = true,
                WrapContents = true,
                BackColor = ColBg,
                FlowDirection = FlowDirection.LeftToRight,
                // CAMBIO CLAVE: Padding interno para que las tarjetas
                // no toquen los bordes del panel
                Padding = new Padding(8, 8, 8, 8)
            };

            pnlContent.Controls.Add(flpCourses);
            Controls.Add(pnlContent);
        }

        // NUEVO MÉTODO: conecta el Resize del FlowPanel
        // Se llama desde el constructor DESPUÉS de que todo está creado
        private void WireResize()
        {
            flpCourses.Resize += (s, e) => RecalcCardSizes();
        }

        // ══════════════════════════════════════════════════════
        //  CÁLCULO RESPONSIVO DEL TAMAÑO DE TARJETAS
        // ══════════════════════════════════════════════════════

        // CAMBIO PRINCIPAL: antes las tarjetas tenían Size fijo (260x200).
        // Ahora se calcula el ancho disponible, se divide entre columnas
        // y cada tarjeta recibe ese ancho exacto → quedan perfectamente
        // alineadas sin huecos ni desbordamientos.
        private void RecalcCardSizes()
        {
            if (flpCourses.Controls.Count == 0) return;

            flpCourses.SuspendLayout();

            int gap = 14;          // espacio entre tarjetas
            int minCardW = 255;         // ancho mínimo por tarjeta
            int available = flpCourses.ClientSize.Width
                               - flpCourses.Padding.Horizontal;

            // ¿Cuántas columnas caben?
            int columns = Math.Max(1, (available + gap) / (minCardW + gap));

            // Ancho exacto para cada tarjeta
            int cardW = (available - gap * (columns - 1)) / columns;
            cardW = Math.Max(minCardW, cardW);

            foreach (Control ctrl in flpCourses.Controls)
            {
                ctrl.Width = cardW;
                ctrl.Height = 205;
                // Margen: mitad del gap en cada lado horizontal,
                // 7 px arriba y abajo
                ctrl.Margin = new Padding(gap / 2, 7, gap / 2, 7);
            }

            flpCourses.ResumeLayout();
        }

        // ══════════════════════════════════════════════════════
        //  IMainView — DisplayCourses
        // ══════════════════════════════════════════════════════
        public void DisplayCourses(List<Course> courses)
        {
            flpCourses.SuspendLayout();
            flpCourses.Controls.Clear();

            // Calcular tamaño inicial (antes del primer Resize)
            int gap = 14;
            int minCardW = 255;
            int available = flpCourses.ClientSize.Width
                            - flpCourses.Padding.Horizontal;

            // Si el panel todavía no tiene ancho real (primer render),
            // usar el ancho del Form menos el sidebar como estimación
            if (available <= 0)
                available = Width - pnlSidebar.Width - 60;

            int columns = Math.Max(1, (available + gap) / (minCardW + gap));
            int cardW = (available - gap * (columns - 1)) / columns;
            cardW = Math.Max(minCardW, cardW);

            foreach (var course in courses)
            {
                var card = new CourseCardControl(course)
                {
                    Width = cardW,
                    Height = 205,
                    Margin = new Padding(gap / 2, 7, gap / 2, 7)
                };
                card.CourseClicked += OnCourseClicked;
                flpCourses.Controls.Add(card);
            }

            lblCoursesCount.Text =
                $"{courses.Count} curso{(courses.Count != 1 ? "s" : "")} " +
                $"encontrado{(courses.Count != 1 ? "s" : "")}";

            flpCourses.ResumeLayout();

            // Forzar recálculo tras el layout inicial
            flpCourses.BeginInvoke(new Action(RecalcCardSizes));
        }

        // ══════════════════════════════════════════════════════
        //  EVENTOS
        // ══════════════════════════════════════════════════════
        private void OnCourseClicked(Course course)
        {
            var detailForm = new CourseDetailForm(course);
            detailForm.ShowDialog(this);
        }

        public void ShowMessage(string message) =>
            MessageBox.Show(message, "CodeAcademy",
                MessageBoxButtons.OK, MessageBoxIcon.Information);

        // ══════════════════════════════════════════════════════
        //  HELPERS
        // ══════════════════════════════════════════════════════
        private GraphicsPath MakeRoundedPath(Rectangle rect, int radius)
        {
            var path = new GraphicsPath();
            int d = radius * 2;
            path.AddArc(rect.X, rect.Y, d, d, 180, 90);
            path.AddArc(rect.Right - d, rect.Y, d, d, 270, 90);
            path.AddArc(rect.Right - d, rect.Bottom - d, d, d, 0, 90);
            path.AddArc(rect.X, rect.Bottom - d, d, d, 90, 90);
            path.CloseFigure();
            return path;
        }
    }
