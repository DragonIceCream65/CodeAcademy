                g.SmoothingMode = SmoothingMode.AntiAlias;
                var rect = new Rectangle(0, 0, pnlSearchBox.Width - 1, pnlSearchBox.Height - 1);
                using var path = MakeRoundedPath(rect, 10);
                using var bgBrush = new SolidBrush(Color.FromArgb(243, 245, 255));
                using var borderPen = new Pen(Color.FromArgb(210, 215, 240), 1.5f);
                g.FillPath(bgBrush, path);
                g.DrawPath(borderPen, path);
                TextRenderer.DrawText(g, "🔍",
                    new Font("Segoe UI Emoji", 10f),
                    new Rectangle(8, 0, 28, 40),
                    Color.FromArgb(150, 160, 190),
                    TextFormatFlags.VerticalCenter | TextFormatFlags.HorizontalCenter);
