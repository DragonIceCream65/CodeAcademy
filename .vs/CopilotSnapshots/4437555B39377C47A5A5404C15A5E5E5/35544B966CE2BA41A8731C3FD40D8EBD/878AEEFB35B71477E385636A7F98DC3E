                BorderStyle = BorderStyle.None,
                Font = new Font("Segoe UI", 9.5f),
                ForeColor = ColPrimary,
                BackColor = Color.FromArgb(243, 245, 255),
                PlaceholderText = "Buscar cursos...",
                Size = new Size(244, 22),
                Location = new Point(36, 9)
